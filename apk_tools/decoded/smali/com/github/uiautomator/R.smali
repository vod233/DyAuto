.class public final Lcom/github/uiautomator/R;
.super Ljava/lang/Object;


# annotations
.annotation system Ldalvik/annotation/MemberClasses;
    value = {
        Lcom/github/uiautomator/R$anim;,
        Lcom/github/uiautomator/R$attr;,
        Lcom/github/uiautomator/R$bool;,
        Lcom/github/uiautomator/R$color;,
        Lcom/github/uiautomator/R$dimen;,
        Lcom/github/uiautomator/R$drawable;,
        Lcom/github/uiautomator/R$id;,
        Lcom/github/uiautomator/R$integer;,
        Lcom/github/uiautomator/R$interpolator;,
        Lcom/github/uiautomator/R$layout;,
        Lcom/github/uiautomator/R$mipmap;,
        Lcom/github/uiautomator/R$string;,
        Lcom/github/uiautomator/R$style;,
        Lcom/github/uiautomator/R$styleable;,
        Lcom/github/uiautomator/R$xml;
    }
.end annotation


# direct methods
.method private constructor <init>()V
    .locals 0

    invoke-direct {p0}, Ljava/lang/Object;-><init>()V

    return-void
.end method
