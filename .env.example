# ===========================================
# SocialAutoAgent 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ===========================================

# DeepSeek API 密钥
DEEPSEEK_API_KEY=your_api_key_here

# AI 模型配置 (可选，默认值如下)
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-flash

# 兼容旧配置: 如果仍使用 DashScope/OpenAI 兼容服务，也可以在 Web 控制台中填写对应 Base URL 和模型名。

# 后端服务端口 (可选)
# BACKEND_PORT=8000

# 前端服务端口 (可选)
# FRONTEND_PORT=8501
